/* DMUX 8 way */

CHIP DMux4Way{

    IN in,sel[3];
    OUT a,b,c,d,e,f,g,h;

    PARTS:
    
    DMux(in=in,sel=sel[2],a=left,b=right);


    DMux(in=left,sel=sel[1],a=l0,b=l1);
    DMux(in=right,sel=sel[1],a=r0,b=r1);

    DMux(in=l0,sel=sel[0],a=a,b=b);
    DMux(in=l1,sel=sel[0],a=c,b=d);
    DMux(in=r0,sel=sel[0],a=e,b=f);
    DMux(in=r1,sel=sel[0],a=g,b=h);
}